local function CompleteRace()
    if not hasIncrementedRace then
        totalRacesCompleted = totalRacesCompleted + 1
        hasIncrementedRace = true
        lastRaceCompleteTime = tick()
        SaveSettings()
        if statsText then statsText.Text = "Total Races: "..totalRacesCompleted end
    end
    if statusText then
        statusText.Text = "Status: Race Completed"
        statusText.TextColor3 = Color3.fromRGB(100,255,100)
    end
    if frameStroke then
        TweenService:Create(frameStroke, TweenInfo.new(0.15), {Color=Color3.fromRGB(80,255,120), Thickness=2.5}):Play()
        task.delay(0.7, function()
            TweenService:Create(frameStroke, TweenInfo.new(0.6,Enum.EasingStyle.Sine), {Color=Color3.fromRGB(45,45,50), Thickness=1}):Play()
        end)
    end
    StopRacing()
    AnimateButtonsOut()
    if autoStartEnabled then
        task.wait(RACE_COMPLETE_COOLDOWN)
        if selectedRace ~= "Race7" and IsPlayerInCar() then
            local queuePos = QUEUE_POSITIONS[selectedRace]
            if queuePos then
                if statusText then
                    statusText.Text = "Status: Returning to queue..."
                    statusText.TextColor3 = Color3.fromRGB(180,180,255)
                end
                TeleportCarToQueue(queuePos)
            end
        end
    end
end

local function StartRacing()
    if raceActive then return end
    if not IsPlayerInCar() then return end
    local cpFolder = GetCheckpointsFolder()
    if not cpFolder then
        if statusText then statusText.Text = "Status: Race not found" statusText.TextColor3 = Color3.fromRGB(255,130,130) end
        task.wait(2)
        if not raceActive and statusText then statusText.Text = "Status: Idle" statusText.TextColor3 = Color3.fromRGB(180,180,180) end
        return
    end
    carModel = GetPlayerCar()
    if not carModel then return end
    carPrimary = (carModel:FindFirstChild("Body") and carModel.Body:FindFirstChild("#Weight"))
        or carModel.PrimaryPart or carModel:FindFirstChild("VehicleSeat")
    if not carPrimary then return end
    carModel.PrimaryPart = carPrimary
    raceActive = true
    currentCheckpoint = 1
    finishReached = false
    checkpointStartTime = tick()
    lastCheckpointNumber = 1
    hasIncrementedRace = false
    CheckPremiumStatus()
    spawn(function()
        for i = WAIT_BEFORE_START, 1, -1 do
            if not raceActive then return end
            if statusText then statusText.Text = "Status: Starting in "..i.."s" statusText.TextColor3 = Color3.fromRGB(255,200,100) end
            task.wait(1)
        end
        if not raceActive then return end
        startButton.Text = ""
        local hide = TweenService:Create(startButton, TweenInfo.new(0.4,Enum.EasingStyle.Back,Enum.EasingDirection.In), {Size=UDim2.new(1,-20,0,0)})
        hide:Play(); hide.Completed:Wait()
        startButton.Visible = false
        AnimateButtonsIn()
        if statusText then statusText.Text = "Status: Racing" statusText.TextColor3 = Color3.fromRGB(100,255,100) end
        spawn(function()
            while raceActive do
                if frameStroke then
                    TweenService:Create(frameStroke, TweenInfo.new(1.2,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut), {Color=Color3.fromRGB(60,110,200),Thickness=1.8}):Play()
                    task.wait(1.2)
                    if raceActive then
                        TweenService:Create(frameStroke, TweenInfo.new(1.2,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut), {Color=Color3.fromRGB(45,45,50),Thickness=1}):Play()
                        task.wait(1.2)
                    end
                end
            end
            if frameStroke then TweenService:Create(frameStroke, TweenInfo.new(0.4), {Color=Color3.fromRGB(45,45,50),Thickness=1}):Play() end
        end)
        spawn(function() while raceActive do setupExistingVehicles() task.wait(1) end end)
        local lastRescanTime = tick()
        checkpointDetectionLoop = RunService.Heartbeat:Connect(function()
            if not raceActive then return end
            if HasRaceEnded() then CompleteRace() return end
            if not IsInRaceUI() then StopRacing() AnimateButtonsOut() return end
            if not IsPlayerInCar() then StopRacing() AnimateButtonsOut() return end
            if not carModel or not carModel.Parent or not carPrimary or not carPrimary.Parent then
                StopRacing() AnimateButtonsOut() return
            end
            if finishReached then return end
            if tick() - lastRescanTime >= 2 then
                local next = FindNextUncollectedCheckpoint()
                if next > currentCheckpoint then currentCheckpoint = next checkpointStartTime = tick() end
                lastRescanTime = tick()
            end
            if currentCheckpoint ~= lastCheckpointNumber then
                checkpointStartTime = tick()
                lastCheckpointNumber = currentCheckpoint
            end
            local cp = FindCheckpoint(currentCheckpoint)
            if cp and IsCheckpointCollected(cp) then
                currentCheckpoint = currentCheckpoint + 1
                checkpointStartTime = tick()
                return
            end
            local targetPos = GetTargetPosition()
            if targetPos then
                if cp and not IsCheckpointCollected(cp) and tick() - checkpointStartTime > TELEPORT_TIMEOUT then
                    TeleportToPosition(targetPos)
                    checkpointStartTime = tick()
                else
                    MoveCarSmoothly(targetPos)
                end
            else
                local finish = FindFinish()
                if finish then
                    if IsCheckpointCollected(finish) then
                        finishReached = true
                        if statusText then statusText.Text = "Status: Finishing..." statusText.TextColor3 = Color3.fromRGB(100,255,255) end
                        task.wait(1)
                        CompleteRace()
                    else
                        MoveCarSmoothly(finish.Position)
                    end
                end
            end
        end)
    end)
end

