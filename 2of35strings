local function addButtonHover(button)
    local origSize = button.Size
    button.MouseEnter:Connect(function()
        hoverSound:Play()
        TweenService:Create(button, TweenInfo.new(0.2), {Size=UDim2.new(origSize.X.Scale,origSize.X.Offset+4,origSize.Y.Scale,origSize.Y.Offset+2)}):Play()
    end)
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {Size=origSize}):Play()
    end)
    button.MouseButton1Down:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1), {Size=UDim2.new(origSize.X.Scale,origSize.X.Offset-4,origSize.Y.Scale,origSize.Y.Offset-2)}):Play()
    end)
    button.MouseButton1Up:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1), {Size=origSize}):Play()
    end)
end

