local function PulseVignette(strength)
    TweenService:Create(vignetteFrame,  TweenInfo.new(0.08,Enum.EasingStyle.Quad,Enum.EasingDirection.Out), {BackgroundTransparency=1-strength}):Play()
    TweenService:Create(vignetteFrameV, TweenInfo.new(0.08,Enum.EasingStyle.Quad,Enum.EasingDirection.Out), {BackgroundTransparency=1-strength}):Play()
    task.delay(0.12, function()
        TweenService:Create(vignetteFrame,  TweenInfo.new(0.65,Enum.EasingStyle.Sine,Enum.EasingDirection.Out), {BackgroundTransparency=1}):Play()
        TweenService:Create(vignetteFrameV, TweenInfo.new(0.65,Enum.EasingStyle.Sine,Enum.EasingDirection.Out), {BackgroundTransparency=1}):Play()
    end)
end

local function TriggerHeartbeat()
    if isHeartbeatPlaying then return end
    isHeartbeatPlaying = true
    heartbeatSound:Play()
    task.delay(1.65, function() heartbeatSound:Stop() end)
    local cam = workspace.CurrentCamera
    local defaultFOV = cam and cam.FieldOfView or 70
    spawn(function()
        PulseVignette(0.82)
        if cam then TweenService:Create(cam, TweenInfo.new(0.08,Enum.EasingStyle.Quad,Enum.EasingDirection.Out), {FieldOfView=defaultFOV-6}):Play() end
        task.wait(0.12)
        if cam then TweenService:Create(cam, TweenInfo.new(0.5,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {FieldOfView=defaultFOV+1.2}):Play() end
        task.wait(0.55)
        if cam then TweenService:Create(cam, TweenInfo.new(0.25,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut), {FieldOfView=defaultFOV}):Play() end
