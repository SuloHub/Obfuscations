startButton.MouseButton1Click:Connect(function()
    clickSound:Play()
    if not IsPlayerInCar() then
        statusText.Text = "Status: Get in car first"
        statusText.TextColor3 = Color3.fromRGB(255,130,130)
        task.wait(2)
        if not raceActive then statusText.Text = "Status: Idle" statusText.TextColor3 = Color3.fromRGB(180,180,180) end
        return
    end
    StartRacing()
end)

stopButton.MouseButton1Click:Connect(function()
    clickSound:Play()
    StopRacing()
    AnimateButtonsOut()
    statusText.Text = "Status: Stopped"
    statusText.TextColor3 = Color3.fromRGB(180,180,180)
    checkpointText.Text = "Checkpoint: 0"
end)

spawn(function()
    while task.wait(0.5) do
        if raceActive and currentCheckpoint ~= lastDisplayedCheckpoint then
            lastDisplayedCheckpoint = currentCheckpoint
            checkpointText.Text = "Checkpoint: "..currentCheckpoint
            cpScale.Scale = 1.3
            TweenService:Create(cpScale, TweenInfo.new(0.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {Scale=1}):Play()
            TweenService:Create(checkpointText, TweenInfo.new(0.1), {TextColor3=Color3.fromRGB(160,255,160)}):Play()
            task.delay(0.35, function()
                TweenService:Create(checkpointText, TweenInfo.new(0.4,Enum.EasingStyle.Sine), {TextColor3=Color3.fromRGB(180,180,180)}):Play()
            end)
        end
    end
end)

local frameDragging = false
local dragInput, dragStart, dragStartPos

guiFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        frameDragging = true
        dragStart = input.Position
        dragStartPos = guiFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then frameDragging = false end
        end)
    end
end)
guiFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and frameDragging then
        local delta = input.Position - dragStart
        guiFrame.Position = UDim2.new(dragStartPos.X.Scale, dragStartPos.X.Offset+delta.X, dragStartPos.Y.Scale, dragStartPos.Y.Offset+delta.Y)
    end
end)

spawn(function()
    while task.wait(0.8) do
        if autoStartEnabled and not raceActive then
            if workspace:FindFirstChild("Races") and IsInRaceUI() and IsPlayerInCar() then
                if tick()-lastRaceCompleteTime >= RACE_COMPLETE_COOLDOWN then
                    task.wait(7)
                    if autoStartEnabled and not raceActive and IsInRaceUI() and IsPlayerInCar() then
                        StartRacing()
                    end
                end
            end
        end
    end
end)

