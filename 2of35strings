local function TeleportCarToQueue(targetPos)
    local car = GetPlayerCar()
    if not car then return false end
    local primary = (car:FindFirstChild("Body") and car.Body:FindFirstChild("#Weight"))
        or car.PrimaryPart or car:FindFirstChild("VehicleSeat")
    if not primary then return false end
    car.PrimaryPart = primary
    local landingCF = CFrame.new(targetPos + Vector3.new(0, CAR_HEIGHT, 0)) * (primary.CFrame - primary.CFrame.Position)
    for _, p in pairs(car:GetDescendants()) do
        if p:IsA("BasePart") then
            p.AssemblyLinearVelocity = Vector3.new(0,0,0)
            p.AssemblyAngularVelocity = Vector3.new(0,0,0)
        end
    end
    car:SetPrimaryPartCFrame(landingCF)
    return true
end

local function TeleportToPosition(position)
    if not carModel or not carPrimary then return end
    local targetPos = position + Vector3.new(0, CAR_HEIGHT, 0)
    local dir = (targetPos - carPrimary.Position).Unit
    local lookDir = Vector3.new(dir.X, 0, dir.Z)
    if lookDir.Magnitude > 0 then
        carModel:SetPrimaryPartCFrame(CFrame.new(targetPos, targetPos + lookDir.Unit))
    else
        carModel:SetPrimaryPartCFrame(CFrame.new(targetPos))
    end
    carPrimary.AssemblyLinearVelocity = Vector3.new(0,0,0)
    carPrimary.AssemblyAngularVelocity = Vector3.new(0,0,0)
end

local function MoveCarSmoothly(targetPosition)
    if not carModel or not carPrimary then return end
    local currentPos = carPrimary.Position
    local dir = (targetPosition - currentPos).Unit
    local distance = (targetPosition - currentPos).Magnitude
    local lookDir = Vector3.new(dir.X, 0, dir.Z)
    if lookDir.Magnitude > 0 then
        local newPos = currentPos + dir * math.min(currentSpeed, distance)
        carModel:SetPrimaryPartCFrame(CFrame.new(newPos, newPos + lookDir.Unit))
        carPrimary.AssemblyLinearVelocity = Vector3.new(0,0,0)
        carPrimary.AssemblyAngularVelocity = Vector3.new(0,0,0)
    end
end

local function GetTargetPosition()
    local cp = FindCheckpoint(currentCheckpoint)
    if cp then return cp.Position end
    return GetManualCheckpointPosition(currentCheckpoint)
end

local function StopRacing()
    raceActive = false
    finishReached = false
    hasIncrementedRace = false
    if checkpointDetectionLoop then
        checkpointDetectionLoop:Disconnect()
        checkpointDetectionLoop = nil
    end
    if carPrimary and carPrimary.Parent then
        carPrimary.AssemblyLinearVelocity = Vector3.new(0,0,0)
        carPrimary.AssemblyAngularVelocity = Vector3.new(0,0,0)
    end
    carModel = nil
    carPrimary = nil
    currentCheckpoint = 1
    checkpointStartTime = 0
    lastCheckpointNumber = 0
end

