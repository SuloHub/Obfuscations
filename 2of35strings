UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local sliderX = speedSlider.AbsolutePosition.X
        local sliderW = speedSlider.AbsoluteSize.X
        local rel = math.clamp((input.Position.X - sliderX) / sliderW, 0, 1)
        local maxSpeed = 24
        local premiumThreshold = 17
        if not isPremium and rel > ((premiumThreshold-1)/(maxSpeed-1)) then
            rel = (premiumThreshold-1)/(maxSpeed-1)
        end
        local prevSpeed = currentSpeed
        currentSpeed = 1 + rel*(maxSpeed-1)
        speedFill.Size = UDim2.new(rel,0,1,0)
        speedKnob.Position = UDim2.new(rel,-10,0.5,-10)

        local now = tick()
        if math.abs(currentSpeed - lastSliderSoundSpeed) >= 0.35 and now - lastTickTime >= 0.05 then
            lastSliderSoundSpeed = currentSpeed
            lastTickTime = now
            local frac = math.clamp((currentSpeed-1)/(maxSpeed-1), 0, 1)
            sliderTickSound.PlaybackSpeed = 0.5 + frac * 1.9
            sliderTickSound.Volume = 0.15 + frac * 0.25
            sliderTickSound:Play()
        end

        if currentSpeed >= WARNING_SPEED and prevSpeed < WARNING_SPEED and not heartbeatTriggered then
            heartbeatTriggered = true
            TriggerHeartbeat()
        end
        if currentSpeed < WARNING_SPEED then
            heartbeatTriggered = false
        end

        local rounded = math.floor(currentSpeed*10)/10
        if not isPremium and currentSpeed >= premiumThreshold then
            speedLabel.Text = "Speed: "..rounded.." (Only premium can go faster)"
            speedLabel.TextColor3 = Color3.fromRGB(255,200,100)
        elseif currentSpeed >= WARNING_SPEED then
            speedLabel.Text = "⚠ Speed: "..rounded.." (Risk of ban!) ⚠"
            speedLabel.TextColor3 = Color3.fromRGB(255,100,100)
        else
            speedLabel.Text = "Speed: "..rounded
            speedLabel.TextColor3 = Color3.fromRGB(180,180,180)
        end
    end
end)

