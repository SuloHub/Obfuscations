local function GetCheckpointsFolder()
    local races = workspace:FindFirstChild("Races")
    if not races then return nil end
    local race = races:FindFirstChild(selectedRace)
    if not race then return nil end
    local rf = race:FindFirstChild("Races")
    if not rf then return nil end
    for _, folder in pairs(rf:GetChildren()) do
        if folder:IsA("Folder") and folder.Name:match("^"..selectedRace.."_") then
            local cv = folder:FindFirstChild("Checkpoints")
            if cv then return cv end
        end
    end
    return nil
end

local function FindCheckpoint(number)
    local folder = GetCheckpointsFolder()
    if not folder then return nil end
    local cp = folder:FindFirstChild(tostring(number))
    if cp and cp:IsA("BasePart") then return cp end
    return nil
end

local function FindFinish()
    local folder = GetCheckpointsFolder()
    if not folder then return nil end
    local f = folder:FindFirstChild("Finish")
    if f and f:IsA("BasePart") then return f end
    return nil
end

local function GetManualCheckpointPosition(number)
    if MANUAL_CHECKPOINTS[selectedRace] and MANUAL_CHECKPOINTS[selectedRace][number] then
        return MANUAL_CHECKPOINTS[selectedRace][number]
    end
    return nil
end

local function IsCheckpointCollected(cp)
    return cp and cp.Transparency >= 0.95
end

local function FindNextUncollectedCheckpoint()
    local folder = GetCheckpointsFolder()
    if not folder then return 1 end
    for i = 1, 100 do
        local cp = folder:FindFirstChild(tostring(i))
        if cp and cp:IsA("BasePart") then
            if not IsCheckpointCollected(cp) then return i end
        else return i end
    end
    return 1
end

