local function SaveSettings()
    local s = {
        selectedRaceShutoko = isShutoko and selectedRace or savedSettings.selectedRaceShutoko,
        selectedRaceSaltFlats = isSaltFlats and selectedRace or savedSettings.selectedRaceSaltFlats,
        speed = math.floor(currentSpeed*10)/10,
        autoStart = autoStartEnabled,
        totalRaces = totalRacesCompleted,
        username = player.Name
    }
    savedSettings = s
    local ok = pcall(function() writefile(SETTINGS_FILE, HttpService:JSONEncode(s)) end)
    if not ok then pcall(function() writefile(SETTINGS_FILE, HttpService:JSONEncode(s)) end) end
end

local function LoadSettings()
    local ok, result = pcall(function() return readfile(SETTINGS_FILE) end)
    if not ok or not result or result == "" then return false end
    local ok2, d = pcall(function() return HttpService:JSONDecode(result) end)
    if not ok2 or not d then return false end
    if d.username ~= player.Name then return false end
    if isShutoko and d.selectedRaceShutoko and RACE_NAMES[d.selectedRaceShutoko] then selectedRace = d.selectedRaceShutoko
    elseif isSaltFlats and d.selectedRaceSaltFlats and RACE_NAMES[d.selectedRaceSaltFlats] then selectedRace = d.selectedRaceSaltFlats end
    if d.speed then currentSpeed = math.floor(d.speed*10)/10 end
    if d.autoStart ~= nil then autoStartEnabled = d.autoStart end
    if d.totalRaces then totalRacesCompleted = d.totalRaces end
    savedSettings = d
    return true
end

local function CheckPremiumStatus()
    if player.Name == "Number1" then
        isPremium = true; return isPremium
    end
    local ok, rank = pcall(function() return player:GetRankInGroup(10612101) end)
    if ok and rank >= 6 then isPremium = true; return isPremium end
    local ok2, res = pcall(function() return MarketplaceService:PlayerOwnsAsset(player, PREMIUM_SHIRT_ID) end)
    isPremium = ok2 and res
    return isPremium
end

local function disableCollision(model)
    local hasShirt = CheckPremiumStatus()
    for _, d in pairs(model:GetDescendants()) do
        if d:IsA("BasePart") then
            d.CanCollide = false
            if hasShirt then d.Transparency = 1 end
            pcall(function() d.CollisionGroup = "NPCVehicles" end)
        end
    end
end

local function setupExistingVehicles()
    local f = workspace:FindFirstChild("NPCVehicles")
    if f then
        local v = f:FindFirstChild("Vehicles")
        if v then
            for _, veh in pairs(v:GetChildren()) do
                if veh:IsA("Model") or veh:IsA("Folder") then disableCollision(veh) end
            end
        end
    end
end

